meta {
  name: 04 Forgot Password
  type: http
  seq: 5
}

post {
  url: {{base_url}}/api/v1/auth/forgot-password/
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "john@example.com"
  }
}

docs {
  Response includes `debug_token` (the 6-digit OTP) when DEBUG=True.
  Copy it into the Reset Password request.
}
