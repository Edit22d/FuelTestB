meta {
  name: 07 Refresh Token
  type: http
  seq: 8
}

post {
  url: {{base_url}}/api/v1/auth/token/refresh/
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "refresh": "{{refresh_token}}"
  }
}

script:post-response {
  if (res.status === 200 && res.body.access) {
    bru.setEnvVar("access_token", res.body.access);
  }
}
